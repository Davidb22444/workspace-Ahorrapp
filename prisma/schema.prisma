generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                   String                @id @default(cuid())
  email                String                @unique
  name                 String
  password             String?
  role                 String                @default("user")
  avatar               String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  budgets              Budget[]
  budgetPeriods        BudgetPeriod[]
  categories           Category[]
  debts                Debt[]
  debtPayments         DebtPayment[]
  dependents           Dependent[]
  expenses             Expense[]
  incomes              Income[]
  movements            Movement[]
  notifications        Notification[]
  savingsContributions SavingsContribution[]
  savingsGoals         SavingsGoal[]
  unexpecteds          Unexpected[]

  @@index([email])
}

model Category {
  id          String       @id @default(cuid())
  name        String
  icon        String       @default("Circle")
  color       String       @default("#6366f1")
  type        String       @default("expense")
  isDefault   Boolean      @default(false)
  accountId   String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  account     Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  expenses    Expense[]
  incomes     Income[]
  movements   Movement[]
  unexpecteds Unexpected[]

  @@index([accountId])
}

model Dependent {
  id             String       @id @default(cuid())
  name           String
  relationship   String       @default("other")
  economicWeight Float        @default(1.0)
  birthDate      DateTime?
  notes          String?
  accountId      String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  account        Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  expenses       Expense[]
  unexpecteds    Unexpected[]

  @@index([accountId])
}

model Movement {
  id          String    @id @default(cuid())
  type        String
  amount      Float
  description String
  date        DateTime  @default(now())
  categoryId  String?
  accountId   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  account     Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  category    Category? @relation(fields: [categoryId], references: [id])

  @@index([accountId])
  @@index([date])
}

model Income {
  id          String    @id @default(cuid())
  source      String
  amount      Float
  description String?
  frequency   String    @default("monthly")
  date        DateTime  @default(now())
  categoryId  String?
  accountId   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  account     Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  category    Category? @relation(fields: [categoryId], references: [id])

  @@index([accountId])
  @@index([date])
}

model Expense {
  id          String     @id @default(cuid())
  amount      Float
  description String
  date        DateTime   @default(now())
  categoryId  String?
  dependentId String?
  isRecurring Boolean    @default(false)
  frequency   String?
  accountId   String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  account     Account    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  category    Category?  @relation(fields: [categoryId], references: [id])
  dependent   Dependent? @relation(fields: [dependentId], references: [id])

  @@index([accountId])
  @@index([date])
}

model Unexpected {
  id          String     @id @default(cuid())
  amount      Float
  description String
  date        DateTime   @default(now())
  categoryId  String?
  dependentId String?
  resolved    Boolean    @default(false)
  accountId   String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  account     Account    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  category    Category?  @relation(fields: [categoryId], references: [id])
  dependent   Dependent? @relation(fields: [dependentId], references: [id])

  @@index([accountId])
}

model Debt {
  id           String        @id @default(cuid())
  name         String
  totalAmount  Float
  paidAmount   Float         @default(0)
  interestRate Float?
  startDate    DateTime      @default(now())
  dueDate      DateTime?
  status       String        @default("pending")
  type         String        @default("loan")
  installments Int?
  accountId    String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  account      Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  payments     DebtPayment[]

  @@index([accountId])
}

model DebtPayment {
  id        String   @id @default(cuid())
  amount    Float
  date      DateTime @default(now())
  note      String?
  debtId    String
  accountId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  debt      Debt     @relation(fields: [debtId], references: [id], onDelete: Cascade)

  @@index([debtId])
  @@index([accountId])
}

model SavingsGoal {
  id            String                @id @default(cuid())
  name          String
  targetAmount  Float
  savedAmount   Float                 @default(0)
  icon          String                @default("PiggyBank")
  color         String                @default("#10b981")
  deadline      DateTime?
  status        String                @default("active")
  accountId     String
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  contributions SavingsContribution[]
  account       Account               @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
}

model SavingsContribution {
  id        String      @id @default(cuid())
  amount    Float
  date      DateTime    @default(now())
  note      String?
  goalId    String
  accountId String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  account   Account     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  goal      SavingsGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([goalId])
  @@index([accountId])
}

model Budget {
  id             String         @id @default(cuid())
  name           String
  totalAmount    Float
  needsPercent   Float          @default(50)
  wantsPercent   Float          @default(30)
  savingsPercent Float          @default(20)
  cycle          String         @default("monthly")
  isActive       Boolean        @default(true)
  accountId      String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  account        Account        @relation(fields: [accountId], references: [id], onDelete: Cascade)
  periods        BudgetPeriod[]

  @@index([accountId])
}

model BudgetPeriod {
  id             String   @id @default(cuid())
  startDate      DateTime
  endDate        DateTime
  plannedIncome  Float
  plannedNeeds   Float
  plannedWants   Float
  plannedSavings Float
  actualIncome   Float    @default(0)
  actualNeeds    Float    @default(0)
  actualWants    Float    @default(0)
  actualSavings  Float    @default(0)
  budgetId       String
  accountId      String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  account        Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  budget         Budget   @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  @@index([budgetId])
  @@index([accountId])
}

model Notification {
  id        String   @id @default(cuid())
  title     String
  message   String
  type      String   @default("info")
  isRead    Boolean  @default(false)
  link      String?
  accountId String
  createdAt DateTime @default(now())
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([isRead])
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String?
  details   String?
  accountId String
  createdAt DateTime @default(now())

  @@index([accountId])
  @@index([createdAt])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model accounts {
  id                    String                  @id @default(dbgenerated("(gen_random_uuid())::text"))
  email                 String                  @unique
  name                  String
  password              String?
  role                  String                  @default("user")
  avatar                String?
  created_at            DateTime                @default(now()) @db.Timestamptz(6)
  updated_at            DateTime                @default(now()) @db.Timestamptz(6)
  budget_periods        budget_periods[]
  budgets               budgets[]
  categories            categories[]
  debt_payments         debt_payments[]
  debts                 debts[]
  dependents            dependents[]
  expenses              expenses[]
  incomes               incomes[]
  movements             movements[]
  notifications         notifications[]
  savings_contributions savings_contributions[]
  savings_goals         savings_goals[]
  unexpecteds           unexpecteds[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model audit_logs {
  id         String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  action     String
  entity     String
  entity_id  String?
  details    String?
  account_id String
  created_at DateTime @default(now()) @db.Timestamptz(6)

  @@index([account_id], map: "idx_audit_logs_account_id")
  @@index([created_at], map: "idx_audit_logs_created_at")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model budget_periods {
  id              String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  start_date      DateTime @db.Timestamptz(6)
  end_date        DateTime @db.Timestamptz(6)
  planned_income  Float
  planned_needs   Float
  planned_wants   Float
  planned_savings Float
  actual_income   Float    @default(0)
  actual_needs    Float    @default(0)
  actual_wants    Float    @default(0)
  actual_savings  Float    @default(0)
  budget_id       String
  account_id      String
  created_at      DateTime @default(now()) @db.Timestamptz(6)
  updated_at      DateTime @default(now()) @db.Timestamptz(6)
  accounts        accounts @relation(fields: [account_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  budgets         budgets  @relation(fields: [budget_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([account_id], map: "idx_budget_periods_account_id")
  @@index([budget_id], map: "idx_budget_periods_budget_id")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
