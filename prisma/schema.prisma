generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model accounts {
  id                    String                  @id @default(dbgenerated("(gen_random_uuid())::text"))
  email                 String                  @unique
  name                  String
  password              String?
  role                  String                  @default("user")
  status                String                  @default("active")
  avatar                String?
  two_factor_secret     String?
  two_factor_recovery_codes String[]
  two_factor_enabled    Boolean                 @default(false)
  two_factor_verified_at DateTime?              @db.Timestamptz(6)
  created_at            DateTime                @default(now()) @db.Timestamptz(6)
  updated_at            DateTime                @default(now()) @db.Timestamptz(6)
  budget_periods        budget_periods[]
  budgets               budgets[]
  categories            categories[]
  debt_payments         debt_payments[]
  debts                 debts[]
  dependents            dependents[]
  expenses              expenses[]
  incomes               incomes[]
  movements             movements[]
  notifications         notifications[]
  savings_contributions savings_contributions[]
  savings_goals         savings_goals[]
  unexpecteds           unexpecteds[]
  email_verifications   email_verification[]  @relation("email_verification_account")
  password_resets       password_reset[]      @relation("password_reset_account")
}

model email_verification {
  id          String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  account_id  String
  token       String   @unique
  expires_at  DateTime @db.Timestamptz(6)
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  account     accounts @relation("email_verification_account", fields: [account_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([account_id], map: "idx_email_verification_account_id")
  @@index([token], map: "idx_email_verification_token")
}

model password_reset {
  id          String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  account_id  String   @unique
  token       String   @unique
  expires_at  DateTime @db.Timestamptz(6)
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  account     accounts @relation("password_reset_account", fields: [account_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([account_id], map: "idx_password_reset_account_id")
  @@index([token], map: "idx_password_reset_token")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model audit_logs {
  id         String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  action     String
  entity     String
  entity_id  String?
  details    String?
  account_id String
  created_at DateTime @default(now()) @db.Timestamptz(6)

  @@index([account_id], map: "idx_audit_logs_account_id")
  @@index([created_at], map: "idx_audit_logs_created_at")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model budget_periods {
  id              String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  start_date      DateTime @db.Timestamptz(6)
  end_date        DateTime @db.Timestamptz(6)
  planned_income  Float
  planned_needs   Float
  planned_wants   Float
  planned_savings Float
  actual_income   Float    @default(0)
  actual_needs    Float    @default(0)
  actual_wants    Float    @default(0)
  actual_savings  Float    @default(0)
  budget_id       String
  account_id      String
  created_at      DateTime @default(now()) @db.Timestamptz(6)
  updated_at      DateTime @default(now()) @db.Timestamptz(6)
  accounts        accounts @relation(fields: [account_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  budgets         budgets  @relation(fields: [budget_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([account_id], map: "idx_budget_periods_account_id")
  @@index([budget_id], map: "idx_budget_periods_budget_id")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model budgets {
  id              String           @id @default(dbgenerated("(gen_random_uuid())::text"))
  name            String
  total_amount    Float
  needs_percent   Float            @default(50)
  wants_percent   Float            @default(30)
  savings_percent Float            @default(20)
  cycle           String           @default("monthly")
  is_active       Boolean          @default(true)
  account_id      String
  created_at      DateTime         @default(now()) @db.Timestamptz(6)
  updated_at      DateTime         @default(now()) @db.Timestamptz(6)
  budget_periods  budget_periods[]
  accounts        accounts         @relation(fields: [account_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([account_id], map: "idx_budgets_account_id")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model categories {
  id          String        @id @default(dbgenerated("(gen_random_uuid())::text"))
  name        String
  icon        String        @default("Circle")
  color       String        @default("#6366f1")
  type        String        @default("expense")
  is_default  Boolean       @default(false)
  account_id  String
  created_at  DateTime      @default(now()) @db.Timestamptz(6)
  updated_at  DateTime      @default(now()) @db.Timestamptz(6)
  accounts    accounts      @relation(fields: [account_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  expenses    expenses[]
  incomes     incomes[]
  movements   movements[]
  unexpecteds unexpecteds[]

  @@index([account_id], map: "idx_categories_account_id")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model debt_payments {
  id         String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  amount     Float
  date       DateTime @default(now()) @db.Timestamptz(6)
  note       String?
  debt_id    String
  account_id String
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)
  accounts   accounts @relation(fields: [account_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  debts      debts    @relation(fields: [debt_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([account_id], map: "idx_debt_payments_account_id")
  @@index([debt_id], map: "idx_debt_payments_debt_id")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model debts {
  id            String          @id @default(dbgenerated("(gen_random_uuid())::text"))
  name          String
  total_amount  Float
  paid_amount   Float           @default(0)
  interest_rate Float?
  start_date    DateTime        @default(now()) @db.Timestamptz(6)
  due_date      DateTime?       @db.Timestamptz(6)
  status        String          @default("pending")
  type          String          @default("loan")
  installments  Int?
  account_id    String
  created_at    DateTime        @default(now()) @db.Timestamptz(6)
  updated_at    DateTime        @default(now()) @db.Timestamptz(6)
  debt_payments debt_payments[]
  accounts      accounts        @relation(fields: [account_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([account_id], map: "idx_debts_account_id")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model dependents {
  id              String        @id @default(dbgenerated("(gen_random_uuid())::text"))
  name            String
  relationship    String        @default("other")
  economic_weight Float         @default(1.0)
  birth_date      DateTime?     @db.Timestamptz(6)
  notes           String?
  account_id      String
  created_at      DateTime      @default(now()) @db.Timestamptz(6)
  updated_at      DateTime      @default(now()) @db.Timestamptz(6)
  accounts        accounts      @relation(fields: [account_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  expenses        expenses[]
  unexpecteds     unexpecteds[]

  @@index([account_id], map: "idx_dependents_account_id")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model expenses {
  id           String      @id @default(dbgenerated("(gen_random_uuid())::text"))
  amount       Float
  description  String
  date         DateTime    @default(now()) @db.Timestamptz(6)
  category_id  String?
  dependent_id String?
  is_recurring Boolean     @default(false)
  frequency    String?
  account_id   String
  created_at   DateTime    @default(now()) @db.Timestamptz(6)
  updated_at   DateTime    @default(now()) @db.Timestamptz(6)
  accounts     accounts    @relation(fields: [account_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  categories   categories? @relation(fields: [category_id], references: [id], onUpdate: NoAction)
  dependents   dependents? @relation(fields: [dependent_id], references: [id], onUpdate: NoAction)

  @@index([account_id], map: "idx_expenses_account_id")
  @@index([date], map: "idx_expenses_date")
  @@index([account_id, date], map: "idx_expenses_account_id_date")
}

